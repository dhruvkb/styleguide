#:schema https://www.schemastore.org/prek.json

[[repos]]
repo = "builtin"
hooks = [
	{ id = "trailing-whitespace", args = [
		"--markdown-linebreak-ext=md,mdx",
	] },
	{ id = "end-of-file-fixer" },
	{ id = "check-json", exclude = "\\.vscode/.*\\.json|\\.oxlintrc\\.json|\\.oxfmtrc\\.json|tsconfig\\.json" },
	{ id = "check-toml" },
	{ id = "check-yaml" },
	{ id = "mixed-line-ending", args = [
		"--fix=lf",
	] },
	{ id = "check-symlinks" },
	{ id = "destroyed-symlinks" },
	{ id = "check-merge-conflict" },
	{ id = "detect-private-key" },
	{ id = "check-shebang-scripts-are-executable" },
	{ id = "check-executables-have-shebangs" },
]

[[repos]]
repo = "https://github.com/editorconfig-checker/editorconfig-checker"
rev = "v3.8.0"
hooks = [{ id = "editorconfig-checker", exclude = "LICENSE$" }]

{% if not exclude_sg %}
[[repos]]
repo = "https://github.com/dhruvkb/styleguide"
rev = "v0.2.0"
hooks = [
	{ id = "no-inline-tabs" },
	{ id = "no-autosquash-commits" },
	{ id = "sg-status" },
	{ id = "sg-validate" },
]

{% endif %}
{% if "python" in languages %}
[[repos]]
repo = "https://github.com/astral-sh/ruff-pre-commit"
rev = "v0.15.20"
hooks = [{ id = "ruff-check", args = ["--fix"] }, { id = "ruff-format" }]

{% endif %}
{% if "javascript" in languages %}
[[repos]]
repo = "local"
hooks = [
	{ id = "oxlint", name = "Oxlint", entry = "pnpm oxlint:fix", language = "system", types_or = [
		{% if "vue" in languages %}
		"vue",
		{% endif %}
		{% if "astro" in languages %}
		"astro",
		{% endif %}
		"javascript",
		"ts",
	] },
]

{% endif %}
[[repos]]
repo = "local"
hooks = [
	{ id = "oxfmt", name = "Oxfmt", entry = "pnpm oxfmt", language = "system", types_or = [
		# Taken from the Oxc compatibility list: https://oxc.rs/compatibility.html
		{% for item in oxfmt_types %}
		"<< item >>",
		{% endfor %}
	], args = [
		# Since there may be files which match `types_or` but are ignored by
		# `.oxfmtrc.json`, we need to silence the error raised when the staged
		# change only has the ignored files.
		"--no-error-on-unmatched-pattern",
	] },
]

{% if "astro" in languages %}
[[repos]]
repo = "local"
hooks = [
	{ id = "eslint", name = "ESLint", entry = "pnpm eslint:fix", language = "system", types_or = [
		"astro",
	] },
	{ id = "prettier", name = "Prettier", entry = "pnpm prettier:write", language = "system", types_or = [
		"astro",
	] },
]

{% endif %}
{% if "rust" in languages %}
[[repos]]
repo = "local"
hooks = [
	{ id = "clippy", name = "clippy", entry = "cargo clippy --fix --all-features --allow-dirty --allow-staged -- -D warnings", language = "system", types_or = [
		"rust",
	], pass_filenames = false },
	{ id = "rustfmt", name = "rustfmt", entry = "cargo fmt", language = "system", types_or = [
		"rust",
	], pass_filenames = false },
	{ id = "test", name = "test", entry = "cargo nextest run", language = "system", types_or = [
		"rust",
	], pass_filenames = false, stages = [
		"pre-push",
	] },
]

{% endif %}
# § project
# § =======

{% block project %}
{% endblock project %}
# /§ project
